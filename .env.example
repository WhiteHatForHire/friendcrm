# Server-side AI key. Do not expose this in browser code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_RESPONSES_ENDPOINT=https://api.openai.com/v1/responses

# Set to 1 for local demo validation when you want safe mock providers even if a key exists.
FRIEND_CRM_DISABLE_PROVIDER=

# Optional if using Anthropic instead.
ANTHROPIC_API_KEY=

# Optional database URL if not using local SQLite.
DATABASE_URL=
